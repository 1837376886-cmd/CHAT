<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.chat.mapper.CsMessageMapper">

    <resultMap id="BaseResultMap" type="com.ruoyi.chat.domain.entity.CsMessage">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="session_id" property="sessionId" jdbcType="BIGINT"/>
        <result column="from_type" property="fromType" jdbcType="TINYINT"/>
        <result column="from_user_id" property="fromUserId" jdbcType="BIGINT"/>
        <result column="content" property="content" jdbcType="VARCHAR"/>
        <result column="msg_type" property="msgType" jdbcType="TINYINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectMessagesBySessionId" resultMap="BaseResultMap">
        SELECT * FROM cs_message
        WHERE session_id = #{sessionId}
        ORDER BY create_time ASC
    </select>

</mapper>
