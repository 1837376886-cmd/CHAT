<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.chat.mapper.CsConfigMapper">

    <resultMap id="BaseResultMap" type="com.ruoyi.chat.domain.entity.CsConfig">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="max_sessions" property="maxSessions" jdbcType="INTEGER"/>
        <result column="auto_reply" property="autoReply" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM cs_config WHERE user_id = #{userId} LIMIT 1
    </select>

</mapper>
