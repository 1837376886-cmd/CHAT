<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.chat.mapper.CsVisitorTagMapper">

    <resultMap id="BaseResultMap" type="com.ruoyi.chat.domain.entity.CsVisitorTag">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="visitor_id" property="visitorId" jdbcType="BIGINT"/>
        <result column="tag_name" property="tagName" jdbcType="VARCHAR"/>
        <result column="create_by" property="createBy" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByVisitorId" resultMap="BaseResultMap">
        SELECT * FROM cs_visitor_tag
        WHERE visitor_id = #{visitorId}
        ORDER BY create_time DESC
    </select>

</mapper>
